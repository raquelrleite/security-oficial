# Banco de Dados
DB_URL=jdbc:mysql://db:3306/spring-oficial?createDatabaseIfNotExist=true
DB_USERNAME=root
DB_PASSWORD=root

# Configurações do Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Segurança (JWT)
# o ideal é ser uma variável de ambiente
JWT_SECRET=minha-chave-que-precisa-ser-grande-aaaa-aaaaaa
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_DAYS=10